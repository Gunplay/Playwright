# Запустити всі тести
npx playwright test

# Запустити конкретний файл
npx playwright test tests/auth/sign-in.spec.js

npx playwright test LocatingMultipleElem.spec.js --project chromium --headed
# Запустити в headed mode (з відкритим браузером)
npx playwright test --headed

# Запустити в debug mode
npx playwright test --debug

# Запустити тільки на Chrome
npx playwright test --project=chromium

# Запустити з UI mode (інтерактивний режим)
npx playwright test --ui

# Відкрити HTML звіт
npx playwright show-report

# Генерація тестів (codegen)
npx playwright codegen https://your-site.com
===============================================================
# 1. Покажіть список всіх знайдених тестів
npx playwright test --list

# 2. Запустіть з повним шляхом
npx playwright test tests/LocatingMultipleElem.spec.js --headed

# 3. Запустіть всі тести
npx playwright test --headed

# 4. Запустіть з grep (якщо в тесті є describe або test з назвою)
npx playwright test --grep "LocateMultiple" --headed

#2. Або запустіть з прапорцем для виводу консолі:
npx playwright test LocatingMultipleElem --reporter=list


